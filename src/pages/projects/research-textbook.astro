---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tags = ["R", "Mixed-Effects Models", "CourseKata", "Research", "ggplot2"];

const researchQuestions = [
  "Can we bridge the gap between textbooks, software, applets, and practice questions by creating a unified platform that enhances ease of navigation with a user-friendly design?",
  "Is an online text with an integrated system more effective than a traditional in-person textbook paired with separate online resources?",
  "What components of the interactive textbook most effectively enhance student learning and engagement?",
  "How do students interact with interactive materials differently from traditional approaches?",
  "What additional components or resources are still needed to optimize the platform?",
];

const contributions = [
  {
    title: "Platform Development",
    subtitle: "Building the Interactive Experience",
    points: [
      "Embedded interactive R coding widgets directly into online text, allowing students to run R code without separate software installations",
      "Integrated statistical applets for simulation, visualization, and probability exploration with toggle-able technology instructions",
      "Converted ISCAM textbook content from original format into Markdown for the CourseKata platform",
      "Developed interactive assessment questions (multiple choice, drag-and-drop, fill-in-the-blank) using the Learnosity framework",
    ],
  },
  {
    title: "Research Design & Data Collection",
    subtitle: "Mixed-Methods Evaluation",
    points: [
      "Served as independent classroom observer documenting student engagement levels using structured observation protocols",
      "Designed and deployed Likert-scale surveys across Winter 2023 (traditional text) and Winter 2024 (CourseKata) cohorts (~150 students)",
      "Completed CITI research ethics certification for researcher-level access to analytics and IRB activities",
    ],
  },
  {
    title: "Statistical Analysis",
    subtitle: "Comparative Analysis in R",
    points: [
      "Cleaned and standardized raw survey exports, extracting Likert scores and combining datasets with year identifiers using tidyverse",
      "Built linear models with section as a random effect using lme4 to account for nested student-within-section structure",
      "Created violin plots, grouped bar charts, and histograms comparing score distributions across years with ggplot2",
      "Analyzed open-ended student responses to categorize qualitative themes in feedback",
    ],
  },
  {
    title: "Grant Writing & Funding",
    subtitle: "Securing Research Support",
    points: [
      "Authored the SoCalGas Student Research Fellowship proposal articulating project background, specific aims, and research design",
      "Contributed to a comprehensive grant proposal ($10,425 + $2,640 student supplement) for expanded 2024/2025 research across seven sections",
      "Developed the foundational project outline defining research questions, experimental design, and phased timeline",
    ],
  },
];

const methodology = [
  { method: "Likert-Scale Surveys", description: "5-point agreement scales on course understanding, expectations, accessibility, office hours, and partner work — administered to ~150 students across two years" },
  { method: "Open-Ended Responses", description: "Free-text student feedback on suggestions, concerns, and experiences" },
  { method: "Classroom Observations", description: "Structured observation protocols with two independent observers comparing engagement across textbook vs. lecture days" },
  { method: "Statistical Modeling", description: "ANOVA and mixed-effects linear models (R, lme4) with section as a random effect" },
  { method: "Platform Analytics", description: "CourseKata built-in metrics including time on page, question completion, and engagement scores" },
  { method: "Focus Groups", description: "Planned follow-up qualitative interviews with students (pending IRB approval)" },
];

const results = [
  "Classroom observers documented higher student engagement on days using the interactive CourseKata textbook compared to traditional lecture-only days",
  "Year-over-year survey comparison showed slight improvements in mean agreement scores on core questions about course understanding and expectations",
  "Student feedback identified specific areas for improvement: textbook layout, ease of reviewing past material, clarity of instructions, and organization",
  "Successfully demonstrated that CourseKata could be implemented within the Canvas ecosystem, integrating applets, R widgets, and instructor dashboards",
];

const conferences = [
  {
    title: "Converting Stat 301 to Online Text Platform for Enhanced Student Learning",
    venue: "eCOTS 2024 (Electronic Conference on Teaching Statistics)",
    type: "Research Poster",
    coAuthors: "Kendall Hipes & Dr. Beth Chance",
  },
  {
    title: "Research Findings Presentation",
    venue: "BCSM Student Research Conference, Cal Poly",
    type: "Co-Presentation",
    coAuthors: "May 2024",
  },
];

const techStack = [
  { group: "Platform", tools: "CourseKata, Canvas LMS, Learnosity, R Widgets" },
  { group: "Analysis", tools: "R, tidyverse, lme4, ggplot2" },
  { group: "Content", tools: "Markdown, Statistical Applets, ISCAM Textbook" },
];

const nextSteps = [
  "Refining the CourseKata textbook based on student feedback — adding videos, pulse questions, and improving note-taking capabilities",
  "Expanded deployment across multiple STAT 301 sections with multiple instructors in the 2024/2025 academic year",
  "Development of a data pipeline integrating CourseKata analytics with Canvas logs for ongoing educational research",
  "Defining design principles extensible to modern interactive textbooks across STEM courses",
];
---

<BaseLayout title="Interactive Textbook Research — Cal Poly | Ben Laufer">
  <!-- Back link -->
  <a href="/projects" class="inline-flex items-center text-sm text-gray-400 hover:text-white transition-colors mb-8 mt-8">
    &larr; Back to Projects
  </a>

  <!-- Hero -->
  <div class="mb-12 animate-fade-in-up">
    <div class="flex items-center gap-4 mb-4">
      <img src="/images/logos/cal-poly.png" alt="Cal Poly" class="h-12 w-auto" />
      <div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white">Interactive Textbook Research</h1>
        <p class="text-accent-blue font-medium">Cal Poly</p>
      </div>
    </div>
    <div class="flex flex-wrap gap-x-6 gap-y-1 text-sm text-gray-400 mb-4">
      <span>Undergraduate Research Assistant &middot; Statistics Department</span>
      <span>2023&ndash;2024</span>
      <span>Faculty Advisor: Dr. Beth Chance</span>
    </div>
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="text-xs px-2 py-1 rounded-full bg-slate-700/50 text-gray-300">{tag}</span>
      ))}
    </div>
  </div>

  <!-- Overview -->
  <section class="mb-12 max-w-3xl animate-fade-in-up" style="animation-delay: 0.1s">
    <h2 class="text-2xl font-bold text-white mb-4">Overview</h2>
    <blockquote class="border-l-2 border-accent-blue/50 pl-4 text-gray-400 leading-relaxed italic">
      A multi-quarter research initiative to transform Cal Poly's STAT 301 course by converting a traditional statistics textbook into an interactive online platform using CourseKata. The project addressed a core problem: students were juggling <strong class="text-white not-italic">separate tools</strong> for reading, coding, simulations, and practice — leading to fragmented learning experiences. Our goal was to unify these into a <strong class="text-white not-italic">single integrated platform</strong> and rigorously evaluate its effectiveness through mixed-methods research.
    </blockquote>
  </section>

  <!-- Research Questions -->
  <section class="mb-12 max-w-3xl animate-fade-in-up" style="animation-delay: 0.15s">
    <h2 class="text-2xl font-bold text-white mb-4">Research Questions</h2>
    <ol class="space-y-3">
      {researchQuestions.map((question, i) => (
        <li class="text-gray-400 leading-relaxed flex gap-3">
          <span class="text-accent-blue font-medium shrink-0">{i + 1}.</span>
          <span>{question}</span>
        </li>
      ))}
    </ol>
  </section>

  <!-- Contributions -->
  <section class="mb-12 animate-fade-in-up" style="animation-delay: 0.2s">
    <h2 class="text-2xl font-bold text-white mb-6">Contributions</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {contributions.map((area, i) => (
        <div class="rounded-xl border border-slate-700/50 bg-white/5 backdrop-blur-sm p-6">
          <div class="text-xs text-accent-blue font-medium uppercase tracking-widest mb-2">Area {i + 1}</div>
          <h3 class="text-lg font-semibold text-white mb-1">{area.title}</h3>
          <p class="text-sm text-gray-500 mb-4">{area.subtitle}</p>
          <ul class="space-y-2">
            {area.points.map((point) => (
              <li class="text-sm text-gray-400 leading-relaxed flex gap-2">
                <span class="text-accent-blue/60 mt-1 shrink-0">&bull;</span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Methodology -->
  <section class="mb-12 max-w-3xl animate-fade-in-up" style="animation-delay: 0.25s">
    <h2 class="text-2xl font-bold text-white mb-4">Methodology</h2>
    <div class="space-y-3">
      {methodology.map((item) => (
        <div class="flex flex-col sm:flex-row sm:gap-4">
          <span class="text-sm font-medium text-accent-blue shrink-0 sm:w-52">{item.method}</span>
          <span class="text-sm text-gray-400">{item.description}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Key Results -->
  <section class="mb-12 max-w-3xl animate-fade-in-up" style="animation-delay: 0.3s">
    <h2 class="text-2xl font-bold text-white mb-4">Key Results</h2>
    <ul class="space-y-3">
      {results.map((result) => (
        <li class="text-gray-400 leading-relaxed flex gap-2">
          <span class="text-accent-blue/60 mt-1 shrink-0">&bull;</span>
          <span>{result}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- Conferences & Presentations -->
  <section class="mb-12 animate-fade-in-up" style="animation-delay: 0.35s">
    <h2 class="text-2xl font-bold text-white mb-6">Conferences & Presentations</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {conferences.map((conf) => (
        <div class="rounded-xl border border-slate-700/50 bg-white/5 backdrop-blur-sm p-6">
          <h3 class="text-lg font-semibold text-white mb-2">{conf.title}</h3>
          <div class="space-y-1 text-sm text-gray-400">
            <p><span class="text-accent-blue">Venue:</span> {conf.venue}</p>
            <p><span class="text-accent-blue">Type:</span> {conf.type}</p>
            <p><span class="text-accent-blue">With:</span> {conf.coAuthors}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Technical Stack -->
  <section class="mb-12 max-w-3xl animate-fade-in-up" style="animation-delay: 0.4s">
    <h2 class="text-2xl font-bold text-white mb-4">Technical Stack</h2>
    <div class="space-y-3">
      {techStack.map((item) => (
        <div class="flex flex-col sm:flex-row sm:gap-4">
          <span class="text-sm font-medium text-accent-blue shrink-0 sm:w-44">{item.group}</span>
          <span class="text-sm text-gray-400">{item.tools}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Impact & Next Steps -->
  <section class="mb-16 max-w-3xl animate-fade-in-up" style="animation-delay: 0.45s">
    <h2 class="text-2xl font-bold text-white mb-4">Impact & Next Steps</h2>
    <ul class="space-y-3">
      {nextSteps.map((step) => (
        <li class="text-gray-400 leading-relaxed flex gap-2">
          <span class="text-accent-blue/60 mt-1 shrink-0">&bull;</span>
          <span>{step}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
