---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Ben Laufer">
  <div class="max-w-3xl space-y-12">
    <!-- Professional Summary -->
    <section class="animate-fade-in-up" style="animation-delay: 0.1s">
      <h1 class="text-3xl font-bold text-white mb-4">About</h1>
      <p class="text-gray-300 leading-relaxed">
        I'm an AI Engineer and data scientist who loves turning raw data into actionable
        strategy. Originally from Los Angeles, I headed to Cal Poly, San Luis Obispo to
        study what I was most curious about — earning a B.S. in Statistics and an M.S. in
        Business Analytics along the way.
      </p>
      <p class="text-gray-300 leading-relaxed mt-4">
        When I'm not writing code, you'll usually find me on a trail or at the gym.
      </p>
    </section>

    <!-- Education -->
    <section class="animate-fade-in-up" style="animation-delay: 0.2s">
      <h2 class="text-xl font-bold text-white mb-4">Education</h2>
      <div class="space-y-4">
        <div class="rounded-lg border border-slate-700/50 bg-white/5 p-5">
          <h3 class="text-white font-semibold">M.S. Business Analytics</h3>
          <p class="text-sm text-gray-400">Cal Poly, San Luis Obispo</p>
        </div>
        <div class="rounded-lg border border-slate-700/50 bg-white/5 p-5">
          <h3 class="text-white font-semibold">B.S. Statistics</h3>
          <p class="text-sm text-gray-400">Cal Poly, San Luis Obispo</p>
        </div>
      </div>
    </section>

    <!-- Skills & Interests -->
    <section class="animate-fade-in-up" style="animation-delay: 0.3s">
      <h2 class="text-xl font-bold text-white mb-4">Skills & Interests</h2>
      <div class="flex flex-wrap gap-2">
        {[
          'Python', 'R', 'TypeScript', 'PyTorch', 'Keras',
          'Machine Learning', 'NLP', 'Deep Learning', 'Statistical Modeling',
          'Data Visualization', 'AI Agents', 'VS Code Extensions',
        ].map((skill) => (
          <span class="text-sm px-3 py-1.5 rounded-full bg-slate-700/50 text-gray-300">
            {skill}
          </span>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
